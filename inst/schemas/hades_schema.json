{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ohdsi.org/hades/results-model/hades_schema.json",
  "title": "HADES Results Data Model Module",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module",
    "prefix",
    "tables"
  ],
  "properties": {
    "module": {
      "type": "string",
      "minLength": 2
    },
    "prefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_$"
    },
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/table"
      }
    }
  },
  "definitions": {
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "fields"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": {
          "type": "string",
          "minLength": 12
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "description",
        "is_primary_key"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 12
        },
        "is_primary_key": {
          "type": "boolean"
        },
        "deprecated": {
          "type": "boolean"
        },
        "references": {
          "type": "string",
          "enum": [
            "cg_cohort_definition.cohort_definition_id",
            "database_meta_data.database_id"
          ]
        }
      }
    }
  }
}
