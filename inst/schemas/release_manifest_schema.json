{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ohdsi.org/hades/results-model/release_manifest_schema.json",
  "title": "HADES Ecosystem Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_version",
    "release_date",
    "modules"
  ],
  "properties": {
    "release_version": {
      "type": "string",
      "pattern": "^v[0-9]{4}_Q[1-4]$"
    },
    "release_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "modules": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    }
  }
}
